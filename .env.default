# ── LLM 백엔드 선택 ──────────────────────────────────
# "ollama" = 로컬 무료 테스트
# "claude" = 배포/데모용 (Claude API 키 필요)
LLM_BACKEND=ollama

# ── Ollama 설정 (로컬 테스트용) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b          

# ── Claude API 설정 (데모/프로덕션 전환 시) ───────────
ANTHROPIC_API_KEY=your_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001   # 가장 저렴

# ── GitHub 설정 ───────────────────────────────────────
GITHUB_TOKEN=github_token_here

# ── 감사 설정 ─────────────────────────────────────────
MIN_CONFIDENCE=0.7          # 이 값 미만이면 오탐으로 필터링
MAX_RETRIES=2               # 자기수정 루프 최대 반복 횟수
REPORT_MODE=pr_comment      # pr_comment | github_issue | both
